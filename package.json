{
  "name": "plead-backend",
  "version": "1.0.0",
  "description": "PropLead AI — Real Estate Lead Engine (Backend)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "dependencies": {
    "@clerk/express": "2.1.32",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "hpp": "0.2.3",
    "lru-cache": "^11.5.1",
    "mongoose": "9.7.3",
    "multer": "1.4.5-lts.2",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "sanitize-html": "^2.17.5",
    "svix": "1.96.1",
    "zod": "4.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/hpp": "0.2.7",
    "@types/jest": "30.0.0",
    "@types/multer": "1.4.12",
    "@types/node": "26.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.4.2",
    "mongodb-memory-server": "9.1.0",
    "prettier": "3.9.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
